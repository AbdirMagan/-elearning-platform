# Example environment variables for production (Render)
# Copy this to a local `.env` for development only. Never commit secrets to git.

# Core
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=maganacademys.onrender.com
SITE_URL=https://maganacademys.onrender.com
CSRF_TRUSTED_ORIGINS=https://maganacademys.onrender.com

# Database: set this in Render dashboard to your Neon/Postgres URL
# Example (Neon PostgreSQL):
# postgresql://neondb_owner:password@host/elearning?sslmode=require
DATABASE_URL=

# Cloudinary (REQUIRED for media file storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Payment Gateways
# WaafiPay
WAAFIPAY_MERCHANT_ID=
WAAFIPAY_API_USER_ID=
WAAFIPAY_API_KEY=
WAAFIPAY_MODE=production

# Sifalo Pay
SIFALO_USERNAME=
SIFALO_PASSWORD=
SIFALO_MODE=sandbox
SIFALO_CALLBACK_URL=https://maganacademys.onrender.com/payments/callback/

# Celery / Redis (optional - only if using async tasks)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
